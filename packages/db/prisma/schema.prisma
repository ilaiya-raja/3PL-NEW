generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ClientStatus {
  PROSPECT
  ONBOARDING
  ACTIVE
  SUSPENDED
  OFFBOARDED
}

enum ZoneType {
  RECEIVING
  RESERVE
  PICK
  PACK
  STAGING
  QUARANTINE
  RETURNS
  YARD
}

enum TempClass {
  AMBIENT
  CHILLED
  FROZEN
}

enum LocationType {
  PICK_FACE
  RESERVE
  STAGING
  DOCK
  YARD
  VIRTUAL
}

enum LotStatus {
  RECEIVED
  AVAILABLE
  PICKED
  ON_HOLD
  QC_HOLD
  QUARANTINE
  DAMAGED
  EXPIRED
}

enum TxnType {
  RECEIPT
  PUTAWAY
  PICK
  PACK
  SHIP
  ADJUST
  TRANSFER_OUT
  TRANSFER_IN
  HOLD
  RELEASE
  COUNT
  RETURN
  ALLOCATE
  DEALLOCATE
}

enum ReceiptStatus {
  EXPECTED
  ARRIVED
  RECEIVING
  QC
  COMPLETE
  CANCELLED
}

enum OrderStatus {
  RECEIVED
  VALIDATED
  ALLOCATED
  RELEASED
  PICKING
  PACKED
  SHIPPED
  CANCELLED
  BACKORDERED
}

enum WaveStatus {
  PLANNING
  RELEASED
  COMPLETE
  CANCELLED
}

enum CartonStatus {
  OPEN
  CLOSED
}

enum ShipStatus {
  CREATED
  MANIFESTED
  IN_TRANSIT
  DELIVERED
  EXCEPTION
  RTO
}

enum OpsRole {
  ADMIN
  SUPERVISOR
  WAREHOUSE_OPS
  BILLING
  READONLY
}

enum PortalRole {
  CLIENT_ADMIN
  ORDER_ENTRY
  VIEWER
}

enum AdjustmentStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum HoldType {
  CLIENT_HOLD
  QC_HOLD
  RECALL_HOLD
  LEGAL_HOLD
}

enum PickTaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETE
  SHORT
  CANCELLED
}

enum ChargeType {
  STORAGE
  PICK
  PACK
  SHIP
  VAS
  COMMIT_TOPUP
}

enum ChargeStatus {
  DRAFT
  INVOICED
  VOID
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
}

enum AppointmentStatus {
  SCHEDULED
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
  CANCELLED
}

// ─── Shared operator tables (no RLS) ─────────────────────────────────────────

model License {
  id           String   @id @default(uuid()) @db.Uuid
  licenseKey   String   @map("license_key") @db.Text
  activatedAt  DateTime @default(now()) @map("activated_at")
  activatedBy  String?  @map("activated_by") @db.Uuid
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("license")
}

model OpsUser {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         OpsRole
  active       Boolean   @default(true)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("ops_user")
}

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  address   Json
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  zones         Zone[]
  locations     Location[]
  inventoryLots InventoryLot[]
  receipts      InboundReceipt[]
  appointments  DockAppointment[]
  orders        OutboundOrder[]
  waves         Wave[]

  @@map("warehouse")
}

model Zone {
  id            String    @id @default(uuid()) @db.Uuid
  warehouseId   String    @map("warehouse_id") @db.Uuid
  code          String
  name          String
  type          ZoneType
  tempClass     TempClass @default(AMBIENT) @map("temp_class")
  hazmatAllowed Boolean   @default(false) @map("hazmat_allowed")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  warehouse Warehouse  @relation(fields: [warehouseId], references: [id])
  locations Location[]

  @@unique([warehouseId, code])
  @@map("zone")
}

model Location {
  id           String       @id @default(uuid()) @db.Uuid
  zoneId       String       @map("zone_id") @db.Uuid
  warehouseId  String       @map("warehouse_id") @db.Uuid
  code         String       @unique
  type         LocationType
  clientId     String?      @map("client_id") @db.Uuid
  pickSequence Int?         @map("pick_sequence")
  maxWeightKg  Decimal?     @map("max_weight_kg") @db.Decimal(14, 3)
  dims         Json?
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  zone          Zone           @relation(fields: [zoneId], references: [id])
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  client        Client?        @relation(fields: [clientId], references: [id])
  inventoryLots InventoryLot[]
  holds         InventoryHold[]

  @@index([warehouseId])
  @@index([clientId])
  @@map("location")
}

model Wave {
  id          String     @id @default(uuid()) @db.Uuid
  warehouseId String     @map("warehouse_id") @db.Uuid
  name        String
  status      WaveStatus @default(PLANNING)
  releasedAt  DateTime?  @map("released_at")
  completedAt DateTime?  @map("completed_at")
  createdBy   String     @map("created_by") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  warehouse Warehouse       @relation(fields: [warehouseId], references: [id])
  orders    OutboundOrder[]
  pickTasks PickTask[]

  @@index([warehouseId, status])
  @@map("wave")
}

model DockAppointment {
  id              String            @id @default(uuid()) @db.Uuid
  warehouseId     String            @map("warehouse_id") @db.Uuid
  receiptId       String?           @map("receipt_id") @db.Uuid
  dockCode        String            @map("dock_code")
  scheduledAt     DateTime          @map("scheduled_at")
  durationMinutes Int               @default(60) @map("duration_minutes")
  carrierName     String?           @map("carrier_name")
  vehicleRef      String?           @map("vehicle_ref")
  driverName      String?           @map("driver_name")
  driverPhone     String?           @map("driver_phone")
  status          AppointmentStatus @default(SCHEDULED)
  checkedInAt     DateTime?         @map("checked_in_at")
  checkedOutAt    DateTime?         @map("checked_out_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  warehouse Warehouse       @relation(fields: [warehouseId], references: [id])
  receipt   InboundReceipt? @relation(fields: [receiptId], references: [id])

  @@index([warehouseId, scheduledAt])
  @@map("dock_appointment")
}

// ─── Tenant tables (RLS required) ────────────────────────────────────────────

model Client {
  id        String       @id @default(uuid()) @db.Uuid
  code      String       @unique
  legalName String       @map("legal_name")
  gstin     String?
  status    ClientStatus @default(ONBOARDING)
  config    Json         @default("{}")
  branding  Json         @default("{}")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  contracts             Contract[]
  portalUsers           PortalUser[]
  items                 Item[]
  inventoryLots         InventoryLot[]
  inventoryTransactions InventoryTransaction[]
  inventoryHolds        InventoryHold[]
  adjustments           Adjustment[]
  inboundReceipts       InboundReceipt[]
  outboundOrders        OutboundOrder[]
  cartons               Carton[]
  shipments             Shipment[]
  pickTasks             PickTask[]
  locations             Location[]
  rateCard              RateCard?
  charges               Charge[]
  invoices              Invoice[]

  @@map("client")
}

model Contract {
  id                String    @id @default(uuid()) @db.Uuid
  clientId          String    @map("client_id") @db.Uuid
  startDate         DateTime  @map("start_date") @db.Date
  endDate           DateTime  @map("end_date") @db.Date
  minMonthlyCommit  Decimal?  @map("min_monthly_commit") @db.Decimal(14, 4)
  renewalAlertDays  Int       @default(30) @map("renewal_alert_days")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  client         Client          @relation(fields: [clientId], references: [id])
  slaDefinitions SlaDefinition[]

  @@index([clientId])
  @@map("contract")
}

model SlaDefinition {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @map("client_id") @db.Uuid
  contractId  String   @map("contract_id") @db.Uuid
  metric      String
  targetValue Decimal  @map("target_value") @db.Decimal(14, 3)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([clientId])
  @@map("sla_definition")
}

model PortalUser {
  id           String     @id @default(uuid()) @db.Uuid
  clientId     String     @map("client_id") @db.Uuid
  email        String     @unique
  passwordHash String     @map("password_hash")
  name         String
  role         PortalRole
  active       Boolean    @default(true)
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@map("portal_user")
}

model Item {
  id              String    @id @default(uuid()) @db.Uuid
  clientId        String    @map("client_id") @db.Uuid
  sku             String
  description     String
  uom             String    @default("EA")
  packConfig      Json      @default("{}") @map("pack_config")
  lotTracked      Boolean   @default(false) @map("lot_tracked")
  serialTracked   Boolean   @default(false) @map("serial_tracked")
  shelfLifeDays   Int?      @map("shelf_life_days")
  minShipShelfPct Decimal?  @map("min_ship_shelf_pct") @db.Decimal(5, 2)
  hazmatClass     String?   @map("hazmat_class")
  tempClass       TempClass @default(AMBIENT) @map("temp_class")
  velocityClass   String?   @map("velocity_class")
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  client                Client                 @relation(fields: [clientId], references: [id])
  inventoryLots         InventoryLot[]
  inventoryTransactions InventoryTransaction[]
  inventoryHolds        InventoryHold[]
  adjustments           Adjustment[]
  inboundLines          InboundLine[]
  outboundLines         OutboundLine[]
  cartonLines           CartonLine[]
  pickTasks             PickTask[]

  @@unique([clientId, sku])
  @@index([clientId])
  @@map("item")
}

model InventoryLot {
  id            String    @id @default(uuid()) @db.Uuid
  clientId      String    @map("client_id") @db.Uuid
  itemId        String    @map("item_id") @db.Uuid
  warehouseId   String    @map("warehouse_id") @db.Uuid
  locationId    String?   @map("location_id") @db.Uuid
  lpn           String?
  lotNumber     String?   @map("lot_number")
  expiryDate    DateTime? @map("expiry_date") @db.Date
  qtyOnHand     Decimal   @default(0) @map("qty_on_hand") @db.Decimal(14, 3)
  qtyAllocated  Decimal   @default(0) @map("qty_allocated") @db.Decimal(14, 3)
  status        LotStatus @default(RECEIVED)
  receivedAt    DateTime  @default(now()) @map("received_at")
  receiptLineId String?   @map("receipt_line_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  client        Client                 @relation(fields: [clientId], references: [id])
  item          Item                   @relation(fields: [itemId], references: [id])
  warehouse     Warehouse              @relation(fields: [warehouseId], references: [id])
  location      Location?              @relation(fields: [locationId], references: [id])
  transactions  InventoryTransaction[]
  holds         InventoryHold[]
  adjustments   Adjustment[]
  allocations   Allocation[]
  cartonLines   CartonLine[]
  pickTasks     PickTask[]

  @@index([clientId, itemId, status, expiryDate])
  @@index([clientId, status])
  @@index([lpn])
  @@map("inventory_lot")
}

model InventoryTransaction {
  id             String     @id @default(uuid()) @db.Uuid
  clientId       String     @map("client_id") @db.Uuid
  txnType        TxnType    @map("txn_type")
  itemId         String     @map("item_id") @db.Uuid
  lotId          String     @map("lot_id") @db.Uuid
  fromLocationId String?    @map("from_location_id") @db.Uuid
  toLocationId   String?    @map("to_location_id") @db.Uuid
  qtyDelta       Decimal    @map("qty_delta") @db.Decimal(14, 3)
  statusFrom     LotStatus? @map("status_from")
  statusTo       LotStatus? @map("status_to")
  refType        String?    @map("ref_type")
  refId          String?    @map("ref_id") @db.Uuid
  actorId        String?    @map("actor_id") @db.Uuid
  notes          String?
  occurredAt     DateTime   @default(now()) @map("occurred_at")
  createdAt      DateTime   @default(now()) @map("created_at")

  client Client       @relation(fields: [clientId], references: [id])
  item   Item         @relation(fields: [itemId], references: [id])
  lot    InventoryLot @relation(fields: [lotId], references: [id])

  @@index([clientId, occurredAt])
  @@index([lotId])
  @@index([refType, refId])
  @@map("inventory_transaction")
}

model InventoryHold {
  id         String    @id @default(uuid()) @db.Uuid
  clientId   String    @map("client_id") @db.Uuid
  itemId     String?   @map("item_id") @db.Uuid
  lotId      String?   @map("lot_id") @db.Uuid
  locationId String?   @map("location_id") @db.Uuid
  holdType   HoldType  @map("hold_type")
  reason     String
  heldBy     String    @map("held_by") @db.Uuid
  releasedBy String?   @map("released_by") @db.Uuid
  releasedAt DateTime? @map("released_at")
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  client   Client        @relation(fields: [clientId], references: [id])
  item     Item?         @relation(fields: [itemId], references: [id])
  lot      InventoryLot? @relation(fields: [lotId], references: [id])
  location Location?     @relation(fields: [locationId], references: [id])

  @@index([clientId, active])
  @@map("inventory_hold")
}

model Adjustment {
  id          String           @id @default(uuid()) @db.Uuid
  clientId    String           @map("client_id") @db.Uuid
  itemId      String           @map("item_id") @db.Uuid
  lotId       String           @map("lot_id") @db.Uuid
  locationId  String?          @map("location_id") @db.Uuid
  qtyDelta    Decimal          @map("qty_delta") @db.Decimal(14, 3)
  reasonCode  String           @map("reason_code")
  notes       String?
  status      AdjustmentStatus @default(PENDING_APPROVAL)
  requestedBy String           @map("requested_by") @db.Uuid
  approvedBy  String?          @map("approved_by") @db.Uuid
  rejectedBy  String?          @map("rejected_by") @db.Uuid
  approvedAt  DateTime?        @map("approved_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  client Client       @relation(fields: [clientId], references: [id])
  item   Item         @relation(fields: [itemId], references: [id])
  lot    InventoryLot @relation(fields: [lotId], references: [id])

  @@index([clientId, status])
  @@map("adjustment")
}

model InboundReceipt {
  id           String        @id @default(uuid()) @db.Uuid
  clientId     String        @map("client_id") @db.Uuid
  warehouseId  String        @map("warehouse_id") @db.Uuid
  asnNumber    String?       @map("asn_number")
  status       ReceiptStatus @default(EXPECTED)
  expectedDate DateTime?     @map("expected_date") @db.Date
  arrivedAt    DateTime?     @map("arrived_at")
  completedAt  DateTime?     @map("completed_at")
  carrierName  String?       @map("carrier_name")
  vehicleRef   String?       @map("vehicle_ref")
  sealNumber   String?       @map("seal_number")
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  client       Client            @relation(fields: [clientId], references: [id])
  warehouse    Warehouse         @relation(fields: [warehouseId], references: [id])
  lines        InboundLine[]
  appointments DockAppointment[]

  @@index([clientId, status])
  @@map("inbound_receipt")
}

model InboundLine {
  id          String    @id @default(uuid()) @db.Uuid
  clientId    String    @map("client_id") @db.Uuid
  receiptId   String    @map("receipt_id") @db.Uuid
  itemId      String    @map("item_id") @db.Uuid
  expectedQty Decimal   @map("expected_qty") @db.Decimal(14, 3)
  receivedQty Decimal   @default(0) @map("received_qty") @db.Decimal(14, 3)
  damagedQty  Decimal   @default(0) @map("damaged_qty") @db.Decimal(14, 3)
  shortQty    Decimal   @default(0) @map("short_qty") @db.Decimal(14, 3)
  lotNumber   String?   @map("lot_number")
  expiryDate  DateTime? @map("expiry_date") @db.Date
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  receipt InboundReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  item    Item           @relation(fields: [itemId], references: [id])

  @@index([receiptId])
  @@index([clientId])
  @@map("inbound_line")
}

model OutboundOrder {
  id           String      @id @default(uuid()) @db.Uuid
  clientId     String      @map("client_id") @db.Uuid
  warehouseId  String      @map("warehouse_id") @db.Uuid
  externalRef  String      @map("external_ref")
  status       OrderStatus @default(RECEIVED)
  shipTo       Json        @map("ship_to")
  billTo       Json?       @map("bill_to")
  priority     Int         @default(5)
  slaShipBy    DateTime?   @map("sla_ship_by")
  waveId       String?     @map("wave_id") @db.Uuid
  notes        String?
  cancelledAt  DateTime?   @map("cancelled_at")
  cancelReason String?     @map("cancel_reason")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  client    Client         @relation(fields: [clientId], references: [id])
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])
  wave      Wave?          @relation(fields: [waveId], references: [id])
  lines     OutboundLine[]
  cartons   Carton[]
  shipments Shipment[]
  pickTasks PickTask[]

  @@unique([clientId, externalRef])
  @@index([clientId, status, slaShipBy])
  @@map("outbound_order")
}

model OutboundLine {
  id                 String   @id @default(uuid()) @db.Uuid
  clientId           String   @map("client_id") @db.Uuid
  orderId            String   @map("order_id") @db.Uuid
  itemId             String   @map("item_id") @db.Uuid
  orderedQty         Decimal  @map("ordered_qty") @db.Decimal(14, 3)
  pickedQty          Decimal  @default(0) @map("picked_qty") @db.Decimal(14, 3)
  packedQty          Decimal  @default(0) @map("packed_qty") @db.Decimal(14, 3)
  backorderedQty     Decimal  @default(0) @map("backordered_qty") @db.Decimal(14, 3)
  requestedLotNumber String?  @map("requested_lot_number")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  order       OutboundOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item        Item          @relation(fields: [itemId], references: [id])
  allocations Allocation[]
  pickTasks   PickTask[]

  @@index([orderId])
  @@index([clientId])
  @@map("outbound_line")
}

model Allocation {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @map("client_id") @db.Uuid
  lineId      String   @map("line_id") @db.Uuid
  lotId       String   @map("lot_id") @db.Uuid
  qty         Decimal  @db.Decimal(14, 3)
  allocatedAt DateTime @default(now()) @map("allocated_at")

  line OutboundLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  lot  InventoryLot @relation(fields: [lotId], references: [id])

  @@unique([lineId, lotId])
  @@index([clientId])
  @@map("allocation")
}

model PickTask {
  id             String         @id @default(uuid()) @db.Uuid
  waveId         String?        @map("wave_id") @db.Uuid
  orderId        String         @map("order_id") @db.Uuid
  lineId         String         @map("line_id") @db.Uuid
  lotId          String         @map("lot_id") @db.Uuid
  fromLocationId String         @map("from_location_id") @db.Uuid
  itemId         String         @map("item_id") @db.Uuid
  clientId       String         @map("client_id") @db.Uuid
  qtyToPick      Decimal        @map("qty_to_pick") @db.Decimal(14, 3)
  qtyPicked      Decimal        @default(0) @map("qty_picked") @db.Decimal(14, 3)
  status         PickTaskStatus @default(OPEN)
  pickSequence   Int            @map("pick_sequence")
  assignedTo     String?        @map("assigned_to") @db.Uuid
  completedAt    DateTime?      @map("completed_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  wave  Wave?         @relation(fields: [waveId], references: [id])
  order OutboundOrder @relation(fields: [orderId], references: [id])
  line  OutboundLine  @relation(fields: [lineId], references: [id])
  lot   InventoryLot  @relation(fields: [lotId], references: [id])
  item  Item          @relation(fields: [itemId], references: [id])
  client Client       @relation(fields: [clientId], references: [id])

  @@index([status, pickSequence])
  @@index([clientId])
  @@map("pick_task")
}

model Carton {
  id        String       @id @default(uuid()) @db.Uuid
  orderId   String       @map("order_id") @db.Uuid
  clientId  String       @map("client_id") @db.Uuid
  cartonNo  String       @map("carton_no")
  dims      Json?
  weightKg  Decimal?     @map("weight_kg") @db.Decimal(14, 3)
  labelUrl  String?      @map("label_url")
  status    CartonStatus @default(OPEN)
  closedAt  DateTime?    @map("closed_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  order  OutboundOrder @relation(fields: [orderId], references: [id])
  client Client        @relation(fields: [clientId], references: [id])
  lines  CartonLine[]

  @@unique([orderId, cartonNo])
  @@index([clientId])
  @@map("carton")
}

model CartonLine {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  cartonId  String   @map("carton_id") @db.Uuid
  itemId    String   @map("item_id") @db.Uuid
  lotId     String   @map("lot_id") @db.Uuid
  qty       Decimal  @db.Decimal(14, 3)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  carton Carton       @relation(fields: [cartonId], references: [id], onDelete: Cascade)
  item   Item         @relation(fields: [itemId], references: [id])
  lot    InventoryLot @relation(fields: [lotId], references: [id])

  @@index([clientId])
  @@map("carton_line")
}

model Shipment {
  id              String     @id @default(uuid()) @db.Uuid
  orderId         String     @map("order_id") @db.Uuid
  clientId        String     @map("client_id") @db.Uuid
  carrierName     String?    @map("carrier_name")
  trackingNumber  String?    @map("tracking_number")
  labelUrl        String?    @map("label_url")
  podUrl          String?    @map("pod_url")
  shipDate        DateTime?  @map("ship_date")
  status          ShipStatus @default(CREATED)
  ewayBillNo      String?    @map("eway_bill_no")
  manifestedAt    DateTime?  @map("manifested_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  order  OutboundOrder @relation(fields: [orderId], references: [id])
  client Client        @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([orderId])
  @@map("shipment")
}

// ─── Billing ─────────────────────────────────────────────────────────────────

model RateCard {
  id                 String   @id @default(uuid()) @db.Uuid
  clientId           String   @unique @map("client_id") @db.Uuid
  currency           String   @default("INR")
  storagePerUnitDay  Decimal  @default(0) @map("storage_per_unit_day") @db.Decimal(14, 4)
  pickPerUnit        Decimal  @default(0) @map("pick_per_unit") @db.Decimal(14, 4)
  packPerOrder       Decimal  @default(0) @map("pack_per_order") @db.Decimal(14, 4)
  shipPerShipment    Decimal  @default(0) @map("ship_per_shipment") @db.Decimal(14, 4)
  vasRates           Json     @default("{}") @map("vas_rates")
  active             Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id])

  @@map("rate_card")
}

model Charge {
  id          String       @id @default(uuid()) @db.Uuid
  clientId    String       @map("client_id") @db.Uuid
  chargeType  ChargeType   @map("charge_type")
  description String
  quantity    Decimal      @db.Decimal(14, 4)
  unitRate    Decimal      @map("unit_rate") @db.Decimal(14, 4)
  amount      Decimal      @db.Decimal(14, 4)
  currency    String       @default("INR")
  periodStart DateTime     @map("period_start") @db.Date
  periodEnd   DateTime     @map("period_end") @db.Date
  sourceRef   String       @map("source_ref")
  status      ChargeStatus @default(DRAFT)
  meta        Json         @default("{}")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  client       Client        @relation(fields: [clientId], references: [id])
  invoiceLines InvoiceLine[]

  @@unique([clientId, chargeType, sourceRef])
  @@index([clientId, status, periodStart])
  @@index([clientId, chargeType])
  @@map("charge")
}

model Invoice {
  id          String        @id @default(uuid()) @db.Uuid
  clientId    String        @map("client_id") @db.Uuid
  invoiceNo   String        @map("invoice_no")
  periodStart DateTime      @map("period_start") @db.Date
  periodEnd   DateTime      @map("period_end") @db.Date
  currency    String        @default("INR")
  subtotal    Decimal       @db.Decimal(14, 4)
  taxAmount   Decimal       @default(0) @map("tax_amount") @db.Decimal(14, 4)
  total       Decimal       @db.Decimal(14, 4)
  status      InvoiceStatus @default(DRAFT)
  issuedAt    DateTime?     @map("issued_at")
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  client Client        @relation(fields: [clientId], references: [id])
  lines  InvoiceLine[]

  @@unique([clientId, invoiceNo])
  @@index([clientId, status])
  @@index([clientId, periodStart])
  @@map("invoice")
}

model InvoiceLine {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @map("client_id") @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
  chargeId    String   @map("charge_id") @db.Uuid
  description String
  amount      Decimal  @db.Decimal(14, 4)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  charge  Charge  @relation(fields: [chargeId], references: [id])

  @@unique([invoiceId, chargeId])
  @@index([clientId])
  @@index([chargeId])
  @@map("invoice_line")
}
