# Deployment
DEPLOYMENT_MODE=onpremise            # onpremise | cloud
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://wms:wms123@localhost:5433/wms_dev

# License (see §7)
LICENSE_KEY=
LICENSE_PUBLIC_KEY=                  # RSA public key baked at build, overridable for dev

# Storage
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wms-documents

# Queue
QUEUE_PROVIDER=nodecron
REDIS_URL=redis://localhost:6379

# Mail
MAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=wms@digisailor.com

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_EXPIRES_IN=7d
NEXTAUTH_SECRET=change-me-nextauth
NEXTAUTH_URL=http://localhost:3000
PORTAL_NEXTAUTH_URL=http://localhost:3001

# URLs / CORS
API_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
